# Databases and their sidecar/backup files
*.db
*.db.bak*
*.db-journal
*.db-wal
*.db-shm

# Logs
*.log

# Reference / sequence data and tabular exports (data artifacts, not code)
*.fasta
*.fa
*.fastq
*.fastq.gz
*.tsv

# Alignment outputs
*.bam
*.bai

# BWA-mem2 index sidecar files
*.bwt.2bit.64
*.0123
*.amb
*.ann
*.pac
*.sa

# Script backups
*.bak

# Runtime temp files / dirs created by sra-trawler-ena.sh
tmp_processing/
tmp_ena_*
counter_ena_*
counter_ena_*.lock
sql_output_*
sql_error_*
*.lock

# Per-organism trawler output lives under {organism}/{species}/{reads,alignments}/.
# The directory names are dynamic, so the data artifacts inside them are excluded
# by the file-type patterns above (*.fastq.gz, *.bam, etc.) rather than by name.
